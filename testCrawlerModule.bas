        Browser_Type = OtherArgs(LBound(OtherArgs))
    Else
        Browser_Type = "Edge": Rem 判斷使用的辨識瀏覽器種類，可以取值：("InternetExplorer", "Edge", "Chrome", "Firefox")
    End If
    'Debug.Print OtherArgs(LBound(OtherArgs))
    'Debug.Print Browser_Type


    '判斷使用的辨識瀏覽器種類，可以取值：("InternetExplorer", "Edge", "Chrome", "Firefox")
    Select Case Browser_Type

        Case Is = "InternetExplorer"

            'Dim i As Integer: Rem 整型，記錄 for 循環次數變量
            Dim tempArr() As String: Rem 字符串分割之後得到的數組

