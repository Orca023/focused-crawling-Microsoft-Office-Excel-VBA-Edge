Public Sub First_level_page_KeyWord_Query(ByVal KeyWord As String, ByVal Current_page_number As Integer, ByVal First_level_page_KeyWord_query_textbox_xpath As String, ByVal First_level_page_KeyWord_query_button_xpath As String, ByVal Browser_Object, ParamArray OtherArgs())
